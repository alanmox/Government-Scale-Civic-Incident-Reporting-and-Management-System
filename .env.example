# ============================================================
# GCIRMS — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_NAME="GCIRMS"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/gcirms/public
APP_TIMEZONE=Africa/Dar_es_Salaam
APP_LOCALE=en

# ============================================================
# Database
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gcirms
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ============================================================
# Security & Encryption
# ============================================================
# 32-byte (64 hex chars) random key — generate with:
# php -r "echo bin2hex(random_bytes(32));"
APP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHAR_KEY_GENERATED_BY_PHP

# ============================================================
# Session
# ============================================================
SESSION_NAME=gcirms_session
SESSION_LIFETIME=1800
SESSION_ABSOLUTE_LIFETIME=28800
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ============================================================
# Mail (SMTP)
# ============================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gcirms.go.tz
MAIL_FROM_NAME="GCIRMS Notification System"

# ============================================================
# SMS Gateway (Africa's Talking or custom)
# ============================================================
SMS_DRIVER=africastalking
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=GCIRMS

# ============================================================
# File Upload
# ============================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,mp4
UPLOAD_PATH=storage/uploads

# ============================================================
# Cache
# ============================================================
CACHE_DRIVER=file
CACHE_PATH=storage/cache
CACHE_DEFAULT_TTL=3600

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug
LOG_PATH=storage/logs

# ============================================================
# Password Policy
# ============================================================
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRY_DAYS=90
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ============================================================
# Pagination
# ============================================================
PAGINATION_DEFAULT=20
PAGINATION_MAX=100

# ============================================================
# SLA Defaults (hours)
# ============================================================
SLA_DEFAULT_RESPONSE=24
SLA_DEFAULT_VERIFICATION=48
SLA_DEFAULT_RESOLUTION=168

# ============================================================
# API
# ============================================================
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# ============================================================
# AWS (Production only)
# ============================================================
AWS_REGION=af-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
